{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-rules.local/schemas/experiment_result.schema.json",
  "title": "ExperimentResult",
  "type": "object",
  "required": [
    "ts",
    "run_id",
    "candidate_id",
    "target_path",
    "baseline_score",
    "candidate_score",
    "delta",
    "decision",
    "decision_reason",
    "evaluation_ok"
  ],
  "additionalProperties": true,
  "properties": {
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "target_path": {
      "type": "string",
      "minLength": 1
    },
    "baseline_score": {
      "type": [
        "number",
        "null"
      ]
    },
    "candidate_score": {
      "type": [
        "number",
        "null"
      ]
    },
    "delta": {
      "type": [
        "number",
        "null"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "accept",
        "revert",
        "skip",
        "propose"
      ]
    },
    "decision_reason": {
      "type": "string",
      "minLength": 1
    },
    "evaluation_ok": {
      "type": "boolean"
    },
    "40_operations/tests": {
      "type": "object"
    },
    "weights": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "thresholds": {
      "type": "object",
      "properties": {
        "accept_threshold": {
          "type": "number"
        },
        "rollback_threshold": {
          "type": "number"
        },
        "tie_breaker": {
          "type": "string",
          "enum": [
            "accept",
            "revert"
          ]
        }
      },
      "required": [
        "accept_threshold",
        "rollback_threshold",
        "tie_breaker"
      ]
    }
  }
}
