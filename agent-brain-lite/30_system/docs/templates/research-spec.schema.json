{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-rules.local/schemas/research-spec.json",
  "title": "ResearchSpecification",
  "type": "object",
  "required": ["version", "research_question", "design_summary"],
  "properties": {
    "version": { "type": "string" },
    "research_question": { "type": "string" },
    "design_summary": { "type": "string", "description": "Study type, PICO or review scope" },
    "reporting_checklist": {
      "type": "string",
      "description": "e.g. CONSORT, PRISMA, STROBE, or N/A"
    },
    "analysis_plan_summary": { "type": "string" },
    "writing_outline": { "type": "string" },
    "sections_or_chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "passes"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "passes": { "type": "boolean" },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "milestones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "passes"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "passes": { "type": "boolean" },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
          "blocked_by": { "type": "array", "items": { "type": "string" } },
          "kind": {
            "type": "string",
            "enum": ["statistics", "writing", "figures", "review", "methods", "mixed"]
          },
          "maps_to_sections": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
