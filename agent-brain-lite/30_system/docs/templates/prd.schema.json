{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-rules.local/schemas/prd.json",
  "title": "ProductRequirementsDocument",
  "type": "object",
  "required": ["version", "problem", "solution", "user_stories"],
  "properties": {
    "version": { "type": "string", "description": "PRD document version" },
    "problem": { "type": "string" },
    "solution": { "type": "string" },
    "user_stories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "passes"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "passes": { "type": "boolean" },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] }
        },
        "additionalProperties": true
      }
    },
    "technical_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["decision", "rationale"],
        "properties": {
          "decision": { "type": "string" },
          "rationale": { "type": "string" },
          "passes": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "execution_chain": {
      "type": "object",
      "properties": {
        "sequence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "verification_protocol": {
      "type": "object",
      "properties": {
        "claim_statuses": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["VERIFIED", "INFERRED", "UNVERIFIED"]
          }
        },
        "baseline_vs_steered": {
          "type": "object",
          "properties": {
            "required": { "type": "boolean" },
            "passes": { "type": "boolean" },
            "notes": { "type": "string" }
          },
          "additionalProperties": true
        },
        "reproducibility": {
          "type": "object",
          "properties": {
            "required": { "type": "boolean" },
            "passes": { "type": "boolean" },
            "seed": { "type": "integer" },
            "environment": { "type": "string" },
            "locked_versions": { "type": "boolean" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "issues": {
      "type": "array",
      "description": "Vertical slices / tasks derived from PRD",
      "items": {
        "type": "object",
        "required": ["id", "title", "passes"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "passes": { "type": "boolean" },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
          "blocked_by": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Issue ids that must pass first"
          },
          "maps_to_stories": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
