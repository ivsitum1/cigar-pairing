{
  "schema_version": 1,
  "default_new_server": 3,
  "tiers": {
    "1": "metadata_only",
    "2": "instruction_access",
    "3": "supervised_execution",
    "4": "autonomous_execution"
  },
  "servers": {
    "filesystem": { "trust_tier": 4, "note": "project-scoped root" },
