    "handoff": { "trust_tier": 4, "note": "local log only" },
    "memory": { "trust_tier": 4, "note": "local sqlite" },
    "pdf": { "trust_tier": 3, "note": "reads user PDFs" },
    "books_rag": { "trust_tier": 4, "note": "local index C:\\books_rag" },
    "latex": { "trust_tier": 3, "note": "shell compile" },
    "overleaf": { "trust_tier": 3, "note": "external sync" },
    "notebooklm": { "trust_tier": 3, "note": "Google OAuth browser" },
    "consensus": { "trust_tier": 3, "note": "external OAuth API" },
    "graphify": { "trust_tier": 4, "note": "local graph.json" }
  }
