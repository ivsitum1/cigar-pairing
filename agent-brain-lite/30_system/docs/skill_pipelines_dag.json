{
  "version": "1.0.0",
  "description": "Declarative named pipeline DAGs for agent-rules. Consumed by skill_dag_validate.py. Aligns with skills-auto-detect.mdc pipeline table.",
  "edge_type_default": "depends_on",
  "pipelines": [
    {
      "id": "agentic-engineering",
      "title": "Agentic PRD + Ralph",
      "entry": "grill-me",
      "exit": "ralph-loop",
      "edges": [
        {"from": "grill-me", "to": "write-prd", "type": "depends_on"},
        {"from": "write-prd", "to": "prd-to-issues", "type": "depends_on"},
        {"from": "prd-to-issues", "to": "ralph-loop", "type": "depends_on"}
      ]
    },
    {
      "id": "scholarly-spec",
      "title": "Scholarly research spec + iteration loop",
      "entry": "research-grill-me",
      "exit": "scholarly-iteration-loop",
      "edges": [
        {"from": "research-grill-me", "to": "write-research-spec", "type": "depends_on"},
        {"from": "write-research-spec", "to": "research-spec-to-milestones", "type": "depends_on"},
        {"from": "research-spec-to-milestones", "to": "scholarly-iteration-loop", "type": "depends_on"}
      ]
    },
    {
      "id": "notebooklm-before-prd",
      "title": "NotebookLM gate before software PRD",
      "entry": "notebooklm-research-gate",
      "exit": "write-prd",
      "optional": true,
      "edges": [
        {"from": "notebooklm-research-gate", "to": "write-prd", "type": "depends_on"}
      ]
    }
  ]
}
