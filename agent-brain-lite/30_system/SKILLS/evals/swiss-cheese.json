{
  "skill_id": "swiss-cheese",
  "version": "1.0",
  "cases": [
    {
      "id": "case_1",
      "input": {
        "text": "Provedi Swiss Cheese validaciju za propensity score matching analizu: opservacijska studija, primarni ishod 30-dnevni mortalitet, n=180. Analiza rađena u R, matching je gotov, ali balance post-matching nije provjeren."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(balance|balans)",
          "description": "contains: balance OR SMD/love plot kao obavezan sloj"
        },
        {
          "type": "regex_match",
          "value": "(?i)(SMD|standardized\\ mean\\ difference)",
          "description": "contains: SMD OR contains: standardized mean difference"
        },
        {
          "type": "not_contains",
          "value": "analiza je ispravna",
          "description": "not_contains: analiza je ispravna"
        },
        {
          "type": "not_contains",
          "value": "validacija je gotova",
          "description": "balance nije provjeren"
        },
        {
          "type": "regex_match",
          "value": "sloj|layer|validacij|provjera|check|love plot",
          "description": "regex_match: sloj|layer|validacij|provjera|check|love plot"
        },
        {
          "type": "last_sentence_not_question",
          "description": "Last sentence not ?"
        }
      ]
    },
    {
      "id": "case_2",
      "input": {
        "text": "Pred slanje rukopisa, Swiss Cheese validacija meta-analize: k=8, pooled OR=0.70, I²=18%, Egger p=0.14, leave-one-out stabilna. Što još ostaje za validirati?"
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(GRADE|certainty)",
          "description": "contains: GRADE OR sigurnost dokaza"
        },
        {
          "type": "regex_match",
          "value": "(?i)(PRISMA|checklist)",
          "description": "contains: PRISMA OR izvještavanje"
        },
        {
          "type": "regex_match",
          "value": "(?i)(protokol|PROSPERO)",
          "description": "contains: protokol OR registracija"
        },
        {
          "type": "regex_match",
          "value": "(?i)(reproducibilnost|reproducibility|seed)",
          "description": "contains: reproducibilnost OR contains: reproducibility OR reproduktivnost koda"
        },
        {
          "type": "regex_match",
          "value": "sloj|layer|provjera|checklist|validacij",
          "description": "regex_match: sloj|layer|provjera|checklist|validacij"
        },
        {
          "type": "word_count_below",
          "value": 500,
          "description": "word_count_below: 500"
        }
      ]
    },
    {
      "id": "case_3",
      "input": {
        "text": "Analitičar tvrdi: \"Swiss Cheese validacija je gotova — provjerio sam p-vrijednosti i napravio forest plot.\" Je li validacija dovoljna?"
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(nije\\ dovoljna|insufficient|nepotpuna)",
          "description": "contains: nije dovoljna OR contains: insufficient OR contains: nepotpuna"
        },
        {
          "type": "regex_match",
          "value": "(?i)(assumptions|pretpostavke)",
          "description": "contains: assumptions OR model assumptions"
        },
        {
          "type": "regex_match",
          "value": "(?i)(reproducibilnost|reproducibility)",
          "description": "contains: reproducibilnost OR contains: reproducibility"
        },
        {
          "type": "not_contains",
          "value": "da, validacija je dovoljna",
          "description": "not_contains: da, validacija je dovoljna"
        },
        {
          "type": "not_contains",
          "value": "prihvatljivo",
          "description": "not_contains: prihvatljivo"
        },
        {
          "type": "regex_match",
          "value": "nedostaje|missing|dodatni sloj|additional layer|samo.{0,30}nedovoljno",
          "description": "regex_match: nedostaje|missing|dodatni sloj|additional layer|sa"
        }
      ]
    },
    {
      "id": "case_4_observational_causal",
      "input": {
        "text": "Retrospektivna kohorta (n=120) pokazuje niži mortalitet uz strategiju A. Autor piše: \"A uzrokuje smanjenje mortaliteta.\" Swiss Cheese prije Discussion."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(confound|konfund|causal|kauzal|opservacij)",
          "description": "flags causal overclaim"
        },
        {
          "type": "not_contains",
          "value": "uzrokuje",
          "description": "does not endorse causal wording"
        },
        {
          "type": "regex_match",
          "value": "(?i)(associated|povezan|ne može se zaključiti|cannot conclude)",
          "description": "appropriate epidemiologic language"
        }
      ]
    }
  ]
}