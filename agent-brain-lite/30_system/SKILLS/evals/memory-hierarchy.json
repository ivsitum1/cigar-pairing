{
  "skill_id": "memory-hierarchy",
  "version": "1.0",
  "cases": [
    {
      "id": "case_fold_lemma_provenance",
      "input": {
        "text": "After sub-goal success, fold micro-history into memory hierarchy with provenance."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(fold-lemma|solved_lemmas|memory_hierarchy|provenance|HORMA|HIPIF)",
          "description": "mentions fold-lemma and hierarchy"
        }
      ]
    },
    {
      "id": "case_sync_command",
      "input": {
        "text": "Bootstrap memory_hierarchy index from existing solved lemmas."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(sync-memory-hierarchy|sync_from_solved_lemmas|index\\.json)",
          "description": "mentions sync command or index"
        }
      ]
    }
  ]
}
