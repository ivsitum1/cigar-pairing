{
  "skill_id": "forest-plot",
  "version": "1.0",
  "cases": [
    {
      "id": "case_1",
      "input": {
        "text": "Napiši R kod za forest plot meta-analize (OR, 95% CI):\nStudy1: OR=0.72, CI=0.51–1.02, w=18%\nStudy2: OR=0.68, CI=0.48–0.96, w=22%\nStudy3: OR=0.81, CI=0.60–1.09, w=20%\nStudy4: OR=0.55, CI=0.38–0.80, w=15%\nStudy5: OR=0.74, CI=0.52–1.05, w=13%\nStudy6: OR=0.69, CI=0.49–0.97, w=12%\nPooled (RE): OR=0.70, CI=0.60–0.82, I²=12%"
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(metafor|meta|forestplot)",
          "description": "contains: metafor OR contains: meta OR paket"
        },
        {
          "type": "regex_match",
          "value": "OR|odds.ratio|log.*OR",
          "description": "regex_match: OR|odds.ratio|log.*OR"
        },
        {
          "type": "regex_match",
          "value": "(?i)(I²|I2|heterogen)",
          "description": "contains: I² OR contains: I2 OR contains: heterogen"
        },
        {
          "type": "regex_match",
          "value": "diamond|pooled|summary|polygon",
          "description": "prikaz pooled estimata"
        },
        {
          "type": "not_contains",
          "value": "lm(",
          "description": "not_contains: lm("
        },
        {
          "type": "not_contains",
          "value": "t.test(",
          "description": "pogrešne funkcije"
        },
        {
          "type": "regex_match",
          "value": "library\\s*\\(",
          "description": "regex_match: library\\s*\\("
        }
      ]
    },
    {
      "id": "case_2",
      "input": {
        "text": "Forest plot za 5 studija, mean difference u QoR-40 score (kontinuirani outcome):\nStudyA: MD=8.2, CI=3.1–13.3\nStudyB: MD=6.5, CI=1.8–11.2\nStudyC: MD=10.1, CI=4.7–15.5\nStudyD: MD=5.8, CI=0.9–10.7\nStudyE: MD=7.4, CI=2.2–12.6"
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(MD|mean\\ difference)",
          "description": "contains: MD OR contains: mean difference"
        },
        {
          "type": "not_contains",
          "value": "OR",
          "description": "not_contains: OR"
        },
        {
          "type": "not_contains",
          "value": "odds ratio",
          "description": "nije binarni ishod"
        },
        {
          "type": "not_contains",
          "value": "log(",
          "description": "ne logaritmira MD"
        },
        {
          "type": "regex_match",
          "value": "yi\\s*=|TE\\s*=|measure\\s*=\\s*['\"]MD|metacont|metagen",
          "description": "regex_match: yi\\s*=|TE\\s*=|measure\\s*=\\s*['\"]MD|metacont|metage"
        },
        {
          "type": "regex_match",
          "value": "rma\\s*\\(|metacont\\s*\\(|metagen\\s*\\(",
          "description": "regex_match: rma\\s*\\(|metacont\\s*\\(|metagen\\s*\\("
        }
      ]
    },
    {
      "id": "case_3",
      "input": {
        "text": "Napravi forest plot za meta-analizu s 2 studije."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(2|dvije\\ studije)",
          "description": "contains: 2 OR prepoznaje mali broj"
        },
        {
          "type": "regex_match",
          "value": "(?i)(upozorenje|caution|ograničenje)",
          "description": "contains: upozorenje OR contains: caution OR contains: ograničenje"
        },
        {
          "type": "not_contains",
          "value": "I²",
          "description": "s 2 studije heterogenost nije interpretabilna"
        },
        {
          "type": "regex_match",
          "value": "minimalan|insufficient|nije preporučeno|not recommended|premalo|k\\s*<\\s*[345]",
          "description": "regex_match: minimalan|insufficient|nije preporučeno|not recomm"
        },
        {
          "type": "last_sentence_not_question",
          "description": "Last sentence not ?"
        }
      ]
    }
  ]
}