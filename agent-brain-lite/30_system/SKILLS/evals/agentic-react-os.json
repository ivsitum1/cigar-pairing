{
  "skill_id": "agentic-react-os",
  "version": "1.0",
  "cases": [
    {
      "id": "case_roadmap_taor",
      "input": {
        "text": "Run in Agentic OS mode: outline how you would debug a flaky test before touching code."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(roadmap|plan|investigat|verify|step)",
          "description": "mentions planning or phased investigation"
        },
        {
          "type": "regex_match",
          "value": "(?i)(TAOR|Think|Observe|Reflect|checkpoint)",
          "description": "mentions TAOR or checkpoint-style discipline"
        },
        {
          "type": "regex_match",
          "value": "(?i)(iteration|escalat|stop)",
          "description": "mentions iteration limit or escalation"
        }
      ]
    },
    {
      "id": "case_tot_debug",
      "input": {
        "text": "Use Tree of Thought to narrow why CI passes locally but fails in GitHub Actions for this repo."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(branch|hypothes|cause|prune|evidence|likely)",
          "description": "multiple hypotheses or ranking language"
        },
        {
          "type": "regex_match",
          "value": "(?i)(CI|Actions|local|environment|matrix)",
          "description": "CI vs local framing"
        }
      ]
    }
  ]
}
