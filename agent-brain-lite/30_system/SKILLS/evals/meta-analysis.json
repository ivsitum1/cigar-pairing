{
  "skill_id": "meta-analysis",
  "version": "1.0",
  "cases": [
    {
      "id": "case_1",
      "input": {
        "text": "Provedi meta-analizu (binarni ishod, 30-dnevni mortalitet). Podaci (events/n tratman vs. kontrola):\nStudy1: 45/200 vs 60/200 | Study2: 30/150 vs 42/150 | Study3: 18/100 vs 28/100\nStudy4: 55/220 vs 70/220 | Study5: 12/80 vs 20/80  | Study6: 22/110 vs 31/110\nR kod s metafor paketom, random effects model (REML), pooled OR i heterogenost."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(metafor|library\\(meta)",
          "description": "contains: metafor OR contains: library(meta"
        },
        {
          "type": "regex_match",
          "value": "(?i)(rma\\(|metabin\\()",
          "description": "contains: rma( OR contains: metabin("
        },
        {
          "type": "regex_match",
          "value": "(?i)(REML|random)",
          "description": "contains: REML OR contains: random"
        },
        {
          "type": "regex_match",
          "value": "(?i)(I²|I2)",
          "description": "contains: I² OR contains: I2"
        },
        {
          "type": "regex_match",
          "value": "escalc\\s*\\(|measure\\s*=\\s*['\"]OR|OR",
          "description": "regex_match: escalc\\s*\\(|measure\\s*=\\s*['\"]OR|OR"
        },
        {
          "type": "not_contains",
          "value": "lm(",
          "description": "pogrešan pristup"
        }
      ]
    },
    {
      "id": "case_2",
      "input": {
        "text": "Meta-analiza pokazuje I²=78% (p<0.001). Dostupni moderatori: tip intervencije (A vs B), setting (ICU vs non-ICU), doza (visoka vs niska). Napiši R kod za subgroup analizu i meta-regresiju."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(subgroup|podgrupa)",
          "description": "contains: subgroup OR contains: podgrupa"
        },
        {
          "type": "regex_match",
          "value": "(?i)(metareg\\(|meta\\-regresija)",
          "description": "contains: metareg( OR contains: meta-regresija"
        },
        {
          "type": "regex_match",
          "value": "(?i)(moderator|moderato)",
          "description": "contains: moderator OR contains: moderato"
        },
        {
          "type": "not_contains",
          "value": "I²=78% je prihvatljiv",
          "description": "nije prihvatljivo bez obrazloženja"
        },
        {
          "type": "regex_match",
          "value": "metareg\\s*\\(|rma\\s*\\(.{0,100}mods\\s*=",
          "description": "regex_match: metareg\\s*\\(|rma\\s*\\(.{0,100}mods\\s*="
        },
        {
          "type": "last_sentence_not_question",
          "description": "Last sentence not ?"
        }
      ]
    },
    {
      "id": "case_3",
      "input": {
        "text": "U meta-analizi 4 studije prijavljuju OR a 3 studije prijavljuju HR za isti ishod (mortalitet). Mogu li ih direktno poolati u jednu meta-analizu?"
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(ne|nije\\ preporučeno|nije\\ ispravno)",
          "description": "contains: ne OR contains: nije preporučeno OR contains: nije ispravno"
        },
        {
          "type": "contains",
          "value": "HR",
          "description": "contains: HR"
        },
        {
          "type": "contains",
          "value": "OR",
          "description": "contains: OR"
        },
        {
          "type": "regex_match",
          "value": "(?i)(transformacij|konzistentnost\\ mjera|conversion)",
          "description": "contains: transformacij OR contains: konzistentnost mjera OR contains: conversion"
        },
        {
          "type": "not_contains",
          "value": "da, možeš",
          "description": "not_contains: da, možeš"
        },
        {
          "type": "not_contains",
          "value": "jednostavno poolaj",
          "description": "not_contains: jednostavno poolaj"
        },
        {
          "type": "regex_match",
          "value": "konzistentno|isti effect measure|standardiz|konverzij|incompatible",
          "description": "regex_match: konzistentno|isti effect measure|standardiz|konver"
        }
      ]
    }
  ]
}