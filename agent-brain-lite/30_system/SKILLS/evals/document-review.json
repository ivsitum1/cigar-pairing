{
  "skill_id": "document-review",
  "version": "1.0",
  "cases": [
    {
      "id": "case_1_math",
      "input": {
        "text": "U izvještaju piše: Regija A 500 + Regija B 300 = ukupno 900. Provjeri dokument."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(800|numerical|matemat|inconsisten|refuted)",
          "description": "catches math error"
        }
      ]
    },
    {
      "id": "case_2_url",
      "input": {
        "text": "Fact-check tvrdnju 'SAD ima 340 milijuna stanovnika' u PDF-u. Nema pristupa internetu."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(ne mogu|cannot verify|pretraž|search|BLANK|izvor)",
          "description": "no fabricated URL"
        },
        {
          "type": "not_contains",
          "value": "https://example.com",
          "description": "no fake URL"
        }
      ]
    }
  ]
}
