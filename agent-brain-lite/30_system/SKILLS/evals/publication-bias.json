{
  "skill_id": "publication-bias",
  "version": "1.0",
  "cases": [
    {
      "id": "case_1",
      "input": {
        "text": "Provedi analizu publication biasa za meta-analizu s k=12 studija (OR effect measure). Napiši R kod za: (1) funnel plot, (2) Egger test, (3) trim-and-fill metodu. Interpretiraj rezultate."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(funnel|funnel_plot|funnel\\.plot)",
          "description": "contains: funnel OR contains: funnel_plot OR contains: funnel.plot"
        },
        {
          "type": "regex_match",
          "value": "(?i)(egger|regtest\\()",
          "description": "contains: egger OR Egger test"
        },
        {
          "type": "regex_match",
          "value": "(?i)(trimfill\\(|trim\\.fill\\(|trimFill)",
          "description": "contains: trimfill( OR contains: trim.fill( OR contains: trimFill"
        },
        {
          "type": "regex_match",
          "value": "library\\s*\\(\\s*['\"]?meta|library\\s*\\(\\s*['\"]?metafor",
          "description": "regex_match: library\\s*\\(\\s*['\"]?meta|library\\s*\\(\\s*['\"]?metaf"
        },
        {
          "type": "last_sentence_not_question",
          "description": "Last sentence not ?"
        }
      ]
    },
    {
      "id": "case_2",
      "input": {
        "text": "Imam meta-analizu s k=7 studija. Treba li provoditi Egger test i trim-and-fill analizu?"
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(nije\\ preporučeno|ograničena\\ snaga|limited\\ power)",
          "description": "contains: nije preporučeno OR contains: ograničena snaga OR contains: limited power"
        },
        {
          "type": "contains",
          "value": "10",
          "description": "navođenje granice k≥10"
        },
        {
          "type": "not_contains",
          "value": "da, provedi Egger",
          "description": "ne smije preporučiti bez upozorenja za k=7"
        },
        {
          "type": "regex_match",
          "value": "snaga|power|ograničen|insufficient|k\\s*[<≥]\\s*10|premalo studij",
          "description": "regex_match: snaga|power|ograničen|insufficient|k\\s*[<≥]\\s*10|p"
        },
        {
          "type": "last_sentence_not_question",
          "description": "Last sentence not ?"
        }
      ]
    },
    {
      "id": "case_3",
      "input": {
        "text": "Interpretiraj ove nalaze i napiši tekst za Discussion: Egger test p=0.03. Trim-and-fill dodao 3 studije, korigirani OR=0.82 (95% CI 0.68–0.99) vs originalni OR=0.70 (95% CI 0.58–0.84)."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(asimetri|asymmetr)",
          "description": "contains: asimetri OR funnel asimetrija"
        },
        {
          "type": "contains",
          "value": "publication bias",
          "description": "termin mora biti korišten"
        },
        {
          "type": "contains",
          "value": "0.82",
          "description": "korigirani estimate"
        },
        {
          "type": "regex_match",
          "value": "3.{0,30}studij|trim.{0,10}fill.{0,50}3|dodane.{0,20}3",
          "description": "regex_match: 3.{0,30}studij|trim.{0,10}fill.{0,50}3|dodane.{0,2"
        },
        {
          "type": "not_contains",
          "value": "nema publication biasa",
          "description": "Egger p=0.03 sugerira bias"
        },
        {
          "type": "regex_match",
          "value": "korigirani|adjusted|trim.{0,10}fill|adjusted estimate",
          "description": "regex_match: korigirani|adjusted|trim.{0,10}fill|adjusted estim"
        },
        {
          "type": "word_count_below",
          "value": 350,
          "description": "word_count_below: 350"
        },
        {
          "type": "last_sentence_not_question",
          "description": "Last sentence not ?"
        }
      ]
    }
  ]
}