{
  "skill_id": "write-research-spec",
  "version": "1.0",
  "cases": [
    {
      "id": "case_research_spec",
      "input": {
        "text": "Napravi research-spec.json za meta-analizu sedacije na ECMO s passes poljima."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(research-spec|passes|PICO|mileston)",
          "description": "research spec with passes"
        },
        {
          "type": "not_contains",
          "value": "PRISMA checklist only",
          "description": "not checklist-only without spec"
        }
      ]
    }
  ]
}
