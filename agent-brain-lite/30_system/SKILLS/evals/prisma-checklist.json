{
  "skill_id": "prisma-checklist",
  "version": "1.0",
  "cases": [
    {
      "id": "case_1",
      "input": {
        "text": "Provjeri PRISMA 2020 usklađenost: prijavljeni eligibility criteria, 4 baze (PubMed, Scopus, WoS, CENTRAL), full search strings, screening (2 recenzenta), data extraction (standardiziran form), RoB 2, forest plot, funnel plot. NIJE prijavljeno: PROSPERO registracija, GRADE procjena sigurnosti."
      },
      "assertions": [
        {
          "type": "contains",
          "value": "PROSPERO",
          "description": "nedostaje, mora biti identificirano"
        },
        {
          "type": "regex_match",
          "value": "(?i)(GRADE|certainty)",
          "description": "contains: GRADE OR nedostaje"
        },
        {
          "type": "not_contains",
          "value": "u potpunosti zadovoljava",
          "description": "not_contains: u potpunosti zadovoljava"
        },
        {
          "type": "not_contains",
          "value": "fully compliant",
          "description": "not_contains: fully compliant"
        },
        {
          "type": "regex_match",
          "value": "nedostaje|nije naveden|missing|incomplete",
          "description": "regex_match: nedostaje|nije naveden|missing|incomplete"
        },
        {
          "type": "contains",
          "value": "PRISMA 2020",
          "description": "contains: PRISMA 2020"
        },
        {
          "type": "last_sentence_not_question",
          "description": "Last sentence not ?"
        }
      ]
    },
    {
      "id": "case_2",
      "input": {
        "text": "Trebam primijeniti PRISMA checklist na scoping review (ne systematic review). Koje su stavke PRISMA 2020 primjenjive, a koje nisu? Specifično: meta-analiza nije rađena, GRADE nije primjenjiv."
      },
      "assertions": [
        {
          "type": "contains",
          "value": "scoping",
          "description": "prepoznaje razliku"
        },
        {
          "type": "regex_match",
          "value": "(?i)(PRISMA\\-ScR|PRISMA\\ for\\ Scoping\\ Reviews)",
          "description": "contains: PRISMA-ScR OR upućuje na ispravno izdanje"
        },
        {
          "type": "not_contains",
          "value": "GRADE je obavezan",
          "description": "GRADE nije za scoping review"
        },
        {
          "type": "contains",
          "value": "eligibility criteria",
          "description": "primjenjivo i za scoping"
        },
        {
          "type": "regex_match",
          "value": "primjenjiv|applicable|nije primjenjiv|not applicable|modific|prilagod",
          "description": "regex_match: primjenjiv|applicable|nije primjenjiv|not applicab"
        }
      ]
    },
    {
      "id": "case_3",
      "input": {
        "text": "Sustavni pregled ima: PROSPERO registraciju, 5 baza, 2 recenzenta za screening, GRADE procjenu, forest plot. Nema: datum zadnje pretrage, contact with study authors, full search strategy u suplementu."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(datum\\ pretrage|search\\ date|last\\ search)",
          "description": "contains: datum pretrage OR contains: search date OR contains: last search"
        },
        {
          "type": "regex_match",
          "value": "(?i)(search\\ strategy|full\\ search)",
          "description": "contains: search strategy OR nepotpun prikaz pretrage"
        },
        {
          "type": "regex_match",
          "value": "(?i)(autori\\ studija|contact\\ with\\ authors)",
          "description": "contains: autori studija OR contains: contact with authors"
        },
        {
          "type": "not_contains",
          "value": "PRISMA compliant",
          "description": "not_contains: PRISMA compliant"
        },
        {
          "type": "not_contains",
          "value": "zadovoljava PRISMA",
          "description": "postoje propusti"
        },
        {
          "type": "regex_match",
          "value": "stavka|item|PRISMA.{0,20}[0-9]|[0-9].{0,20}PRISMA",
          "description": "PRISMA item brojevi"
        }
      ]
    }
  ]
}