{
  "skill_id": "consort-checklist",
  "version": "1.0",
  "cases": [
    {
      "id": "case_1",
      "input": {
        "text": "Provjeri CONSORT 2010 usklađenost i navedi koje su stavke nedostajuće ili nepotpune:\n\"Patients were randomized 1:1 to TIVA or sevoflurane. Randomization was performed using a computer-generated list. Both patients and surgeons were blinded to group allocation. Primary endpoint was QoR-40 at 24h. We enrolled 120 patients between January and December 2023.\""
      },
      "assertions": [
        {
          "type": "contains",
          "value": "allocation concealment",
          "description": "nije opisan, mora biti označeno"
        },
        {
          "type": "regex_match",
          "value": "1b|sequence generation|item [0-9]",
          "description": "CONSORT item reference"
        },
        {
          "type": "not_contains",
          "value": "sve stavke su prisutne",
          "description": "not_contains: sve stavke su prisutne"
        },
        {
          "type": "not_contains",
          "value": "zadovoljava sve",
          "description": "nedostaju elementi"
        },
        {
          "type": "contains",
          "value": "CONSORT",
          "description": "eksplicitno referenciranje"
        },
        {
          "type": "regex_match",
          "value": "nedostaje|nije naveden|missing|incomplete|nepotpun",
          "description": "regex_match: nedostaje|nije naveden|missing|incomplete|nepotpun"
        },
        {
          "type": "last_sentence_not_question",
          "description": "Last sentence not ?"
        }
      ]
    },
    {
      "id": "case_2",
      "input": {
        "text": "Evaluiraj CONSORT usklađenost za open-label RCT (kirurška intervencija vs. konzervativno liječenje) gdje zasljepljenje pacijenata nije moguće. Koje CONSORT stavke su primjenjive, a koje nisu? S obrazloženjem."
      },
      "assertions": [
        {
          "type": "contains",
          "value": "open-label",
          "description": "prepoznaje prirodu studije"
        },
        {
          "type": "regex_match",
          "value": "(?i)(performance\\ bias|detection\\ bias)",
          "description": "contains: performance bias OR relevantni rizici pristranosti"
        },
        {
          "type": "regex_match",
          "value": "(?i)(assessor|outcome\\ assessor)",
          "description": "contains: assessor OR zasljepljenje procjenitelja kao alternativa"
        },
        {
          "type": "not_contains",
          "value": "blinding je obavezan",
          "description": "not_contains: blinding je obavezan"
        },
        {
          "type": "not_contains",
          "value": "studija ne zadovoljava",
          "description": "razumije iznimku"
        },
        {
          "type": "regex_match",
          "value": "primjenjiv|applicable|nije primjenjiv|not applicable|modific",
          "description": "regex_match: primjenjiv|applicable|nije primjenjiv|not applicab"
        }
      ]
    },
    {
      "id": "case_3",
      "input": {
        "text": "Ocijeni CONSORT usklađenost: studija prijavljuje CONSORT flow dijagram, ITT analizu, p-vrijednosti, demografske tablice, broj izgubljenih iz praćenja. Autori tvrde da je studija \"fully CONSORT compliant.\""
      },
      "assertions": [
        {
          "type": "not_contains",
          "value": "fully compliant",
          "description": "not_contains: fully compliant"
        },
        {
          "type": "not_contains",
          "value": "u potpunosti zadovoljava",
          "description": "bez kompletne provjere ne može se tvrditi"
        },
        {
          "type": "regex_match",
          "value": "(?i)(protokol|protocol\\ registration|PROSPERO|ClinicalTrials)",
          "description": "contains: protokol OR contains: protocol registration OR contains: PROSPERO OR česta nedostatak"
        },
        {
          "type": "regex_match",
          "value": "(?i)(sample\\ size|veličina\\ uzorka)",
          "description": "contains: sample size OR kalkulacija uzorka česta nedostatak"
        },
        {
          "type": "regex_match",
          "value": "nije dostatan|insufficient|nedovoljan|incomplete|nepotpun|provjerit",
          "description": "regex_match: nije dostatan|insufficient|nedovoljan|incomplete|n"
        }
      ]
    }
  ]
}