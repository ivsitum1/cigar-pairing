{
  "harness_id": "skill-verifier-gate",
  "version": "1.0",
  "description": "Smoke eval for SkillLens verifier CLI (Relation-Conditioned RC-3)",
  "cases": [
    {
      "id": "case_meta_analysis_accept",
      "input": {
        "prompt": "meta-analysis forest plot pooled effect"
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "\"action\"\\s*:\\s*\"(ACCEPT|DECOMPOSE)\"",
          "description": "returns ACCEPT or DECOMPOSE for meta-analysis prompt"
        },
        {
          "type": "regex_match",
          "value": "meta-analysis",
          "description": "includes meta-analysis skill id"
        }
      ]
    },
    {
      "id": "case_unrelated_skip",
      "input": {
        "prompt": "weather forecast tomorrow Zagreb"
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "\"action\"\\s*:\\s*\"SKIP\"",
          "description": "unrelated prompt yields SKIP for top skills"
        }
      ]
    }
  ]
}
