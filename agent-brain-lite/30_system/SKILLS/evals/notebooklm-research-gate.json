{
  "skill_id": "notebooklm-research-gate",
  "version": "1.0",
  "cases": [
    {
      "id": "case_gate_before_build",
      "input": {
        "text": "NotebookLM kaze da steering daje +40% benchmark boost. Mogu li odmah implementirati u agent rules?"
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(VERIFIED|INFERRED|UNVERIFIED|baseline|reproducib|source|notebooklm|GO|NO-GO)",
          "description": "explicit claim status and provenance gate"
        },
        {
          "type": "not_contains",
          "value": "implement immediately without verification",
          "description": "must not skip verification gate"
        }
      ]
    },
    {
      "id": "case_export_workflow",
      "input": {
        "text": "Export NotebookLM chat and prepare gate report before harness changes."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(notebooklm_bridge|gate-report|claim|VERIFIED|export)",
          "description": "mentions bridge workflow"
        }
      ]
    }
  ]
}
