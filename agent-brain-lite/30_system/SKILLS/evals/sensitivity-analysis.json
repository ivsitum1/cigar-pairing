{
  "skill_id": "sensitivity-analysis",
  "version": "1.0",
  "cases": [
    {
      "id": "case_1",
      "input": {
        "text": "Provedi sensitivity analizu za meta-analizu s k=8 studija (pooled OR=0.70, I²=18%). Napiši R kod za leave-one-out analizu i influence plot."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(leave\\.one\\.out\\(|leave_one_out|l1o)",
          "description": "contains: leave.one.out( OR contains: leave_one_out OR contains: l1o"
        },
        {
          "type": "regex_match",
          "value": "(?i)(influence|influence\\ plot|baujat)",
          "description": "contains: influence OR contains: influence plot OR contains: baujat"
        },
        {
          "type": "regex_match",
          "value": "(?i)(metafor|dmetar|library\\(meta)",
          "description": "contains: metafor OR contains: dmetar OR contains: library(meta"
        },
        {
          "type": "regex_match",
          "value": "leave.one.out|influence\\s*\\(|baujat",
          "description": "regex_match: leave.one.out|influence\\s*\\(|baujat"
        },
        {
          "type": "not_contains",
          "value": "nije potrebno",
          "description": "sensitivity analiza je standardni korak"
        },
        {
          "type": "last_sentence_not_question",
          "description": "Last sentence not ?"
        }
      ]
    },
    {
      "id": "case_2",
      "input": {
        "text": "Leave-one-out pokazuje: bez StudyC pooled OR=0.61 (95% CI 0.49–0.76, I²=5%); sa StudyC pooled OR=0.70 (CI 0.58–0.84, I²=18%). StudyC: n=950, high RoB. Interpretiraj za Discussion."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(StudyC|utjecajna\\ studija|influential)",
          "description": "contains: StudyC OR contains: utjecajna studija OR contains: influential"
        },
        {
          "type": "regex_match",
          "value": "(?i)(high\\ RoB|visok\\ rizik\\ pristranosti)",
          "description": "contains: high RoB OR contains: visok rizik pristranosti"
        },
        {
          "type": "contains",
          "value": "sensitivity",
          "description": "ključni termin"
        },
        {
          "type": "not_contains",
          "value": "zaključak se ne mijenja",
          "description": "I² i CI se mijenjaju"
        },
        {
          "type": "regex_match",
          "value": "utjecaj|influential|mijenja|heterogenost.{0,50}smanji|I².{0,50}5",
          "description": "regex_match: utjecaj|influential|mijenja|heterogenost.{0,50}sma"
        },
        {
          "type": "last_sentence_not_question",
          "description": "Last sentence not ?"
        }
      ]
    },
    {
      "id": "case_3",
      "input": {
        "text": "Provedi sensitivity analizu stratificiranu po dizajnu: prospektivne studije (k=4, OR=0.62), retrospektivne (k=4, OR=0.81). Napiši R kod i interpretiraj razliku između podgrupa, uključujući test za interakciju."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(prospektivn|prospective)",
          "description": "contains: prospektivn OR contains: prospective"
        },
        {
          "type": "regex_match",
          "value": "(?i)(retrospektivn|retrospective)",
          "description": "contains: retrospektivn OR contains: retrospective"
        },
        {
          "type": "contains",
          "value": "0.62",
          "description": "contains: 0.62"
        },
        {
          "type": "contains",
          "value": "0.81",
          "description": "contains: 0.81"
        },
        {
          "type": "regex_match",
          "value": "Q_between|Q_b|test.{0,20}interaction|between.group|interakcij",
          "description": "regex_match: Q_between|Q_b|test.{0,20}interaction|between.group"
        },
        {
          "type": "not_contains",
          "value": "nema razlike između podgrupa",
          "description": "bez formalnog testa interakcije ne može se zaključiti"
        },
        {
          "type": "last_sentence_not_question",
          "description": "Last sentence not ?"
        }
      ]
    }
  ]
}