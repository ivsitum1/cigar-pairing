{
  "skill_id": "write-prd",
  "version": "1.0",
  "cases": [
    {
      "id": "case_prd_passes",
      "input": {
        "text": "Napiši PRD za export CSV feature; koristi prd.json s passes flagovima."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(passes|user stor|problem statement|prd\\.json)",
          "description": "PRD structure with passes"
        },
        {
          "type": "not_contains",
          "value": "PRISMA",
          "description": "not systematic review PRISMA"
        }
      ]
    }
  ]
}
