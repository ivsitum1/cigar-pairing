{
  "skill_id": "manuscript-writing",
  "version": "1.1",
  "cases": [
    {
      "id": "case_file_hygiene",
      "input": {
        "text": "Uredi manuskript CRAB_colistin_v1.0.docx, popravi reference i formatiranje."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(v1\\.1|jedan|single|one file|batch|changelog)",
          "description": "single-file batch edit workflow"
        },
        {
          "type": "not_contains",
          "value": "_pre_",
          "description": "no pre backup files"
        }
      ]
    },
    {
      "id": "case_declarations",
      "input": {
        "text": "Provjeri Declarations sekciju — headeri ne odgovaraju sadržaju."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(header|content|permut|Declarations|verify)",
          "description": "declarations header-content check"
        }
      ]
    },
    {
      "id": "case_style_qc",
      "input": {
        "text": "Revidiraj Discussion cohort studije — previše hedginga, samo 3 paragrafa."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(hedg|may|might|5 paragraph|reference density|9/10|QC)",
          "description": "style and QC pass"
        }
      ]
    },
    {
      "id": "case_n_mismatch_stop",
      "input": {
        "text": "Manuscript kaže N=59 u Table 1 i Results, ali QA audit koristi N=90. Nastavi s revizijom Discussiona."
      },
      "assertions": [
        {
          "type": "regex_match",
          "value": "(?i)(STOP|razjasni|clarify|N=59|N=90|diskrepanc|mismatch|ne generir|do not deliver|prije nastav)",
          "description": "stop output on unresolved N discrepancy"
        }
      ]
    }
  ]
}
