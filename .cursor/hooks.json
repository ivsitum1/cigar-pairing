{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "py scripts/check_sync.py",
        "timeout": 35
      },
      {
        "command": "py .cursor/hooks/memory_lifecycle.py",
        "timeout": 15
      },
      {
        "command": "py .cursor/hooks/books_rag_lifecycle.py",
        "timeout": 30
      },
      {
        "command": "py .cursor/hooks/trajectory_lifecycle.py",
        "timeout": 10
      },
      {
        "command": "py .cursor/hooks/distillation_lifecycle.py",
        "timeout": 10
      },
      {
        "command": "py .cursor/hooks/output_gate_lifecycle.py",
        "timeout": 10
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "py .cursor/hooks/memory_lifecycle.py",
        "timeout": 15
      },
      {
        "command": "py .cursor/hooks/context_compress_lifecycle.py",
        "timeout": 10
      },
      {
        "command": "py .cursor/hooks/books_rag_lifecycle.py",
        "timeout": 30
      },
      {
        "command": "py .cursor/hooks/relation_conditioned_lifecycle.py",
        "timeout": 25
      }
    ],
    "postToolUse": [
      {
        "command": "py .cursor/hooks/memory_lifecycle.py",
        "timeout": 20
      },
      {
        "command": "py .cursor/hooks/trajectory_lifecycle.py",
        "timeout": 10
      },
      {
        "command": "py .cursor/hooks/distillation_lifecycle.py",
        "timeout": 10
      },
      {
        "command": "py .cursor/hooks/relation_conditioned_lifecycle.py",
        "timeout": 20,
        "matcher": "Grep|grep|Shell"
      },
      {
        "command": "py .cursor/hooks/output_gate_lifecycle.py",
        "timeout": 10,
        "matcher": "Write|StrReplace|ApplyPatch|EditNotebook|write|edit"
      }
    ],
    "sessionEnd": [
      {
        "command": "py .cursor/hooks/memory_lifecycle.py",
        "timeout": 15
      },
      {
        "command": "py .cursor/hooks/trajectory_lifecycle.py",
        "timeout": 10
      },
      {
        "command": "py .cursor/hooks/verifier_learning_lifecycle.py",
        "timeout": 120
      },
      {
        "command": "py .cursor/hooks/distillation_lifecycle.py",
        "timeout": 15
      },
      {
        "command": "py .cursor/hooks/output_gate_lifecycle.py",
        "timeout": 60
      },
      {
        "command": "py .cursor/hooks/learning_lifecycle.py",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": "py .cursor/hooks/memory_lifecycle.py",
        "timeout": 15
      },
      {
        "command": "py .cursor/hooks/trajectory_lifecycle.py",
        "timeout": 10
      },
      {
        "command": "py .cursor/hooks/verifier_learning_lifecycle.py",
        "timeout": 120
      },
      {
        "command": "py .cursor/hooks/distillation_lifecycle.py",
        "timeout": 15
      },
      {
        "command": "py .cursor/hooks/output_gate_lifecycle.py",
        "timeout": 60
      },
      {
        "command": "py .cursor/hooks/learning_lifecycle.py",
        "timeout": 10
      }
    ]
  }
}